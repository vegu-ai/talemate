{% include "content-classification.jinja2" %}
{% if include_scenario_premise %}
Scenario Premise:
{{ scene.description }}

{% endif %}
{% if include_scene_intent %}
{% with exclude_phase_intent=exclude_phase_intent|default(False) %}{% include "scene-intent.jinja2" %}{% endwith %}
{% endif %}
{% block rendered_context_static %}
{# GENERAL REINFORCEMENTS #}
{% set general_reinforcements = scene.world_state.filter_reinforcements(insert=reinforcement_inserts|default(['all-context'])) -%}
{%- for reinforce in general_reinforcements %}
{{ reinforce.as_context_line|condensed }}

{% endfor %}
{# END GENERAL REINFORCEMENTS #}
{# CHARACTER SPECIFIC REINFORCEMENTS #}
{% if reinforcement_character and reinforcement_character_inserts %}
{% set char_reinforcements = scene.world_state.filter_reinforcements(character=reinforcement_character, insert=reinforcement_character_inserts) -%}
{%- for reinforce in char_reinforcements %}
{{ reinforce.as_context_line|condensed }}

{% endfor %}
{% endif %}
{# END CHARACTER SPECIFIC REINFORCEMENTS #}
{# ACTIVE PINS #}
{% if scene.active_pins and technical %}<|SECTION:ACTIVE PINS|>{% endif %}
{%- for pin in scene.active_pins %}
{% if technical %}`{{ pin.context_id }}`: {% else %}{{ pin.title }}: {{ pin.time_aware_text|condensed }}{% endif %}
---
{% endfor %}
{# END ACTIVE PINS #}
