{# MEMORY QUERY #}
{%- if memory_query %}
{% set memory_results = query_memory(memory_query, as_question_answer=False, max_tokens=max_tokens|default(500), iterate=iterate|default(10)) -%}
{% if memory_results and memory_results|length > 0 %}
{% set has_content = namespace(value=false) %}
{%- for memory in memory_results -%}
{% if memory and memory|string|trim %}{% set has_content.value = true %}{% endif %}
{%- endfor -%}
{% if has_content.value %}
<|SECTION:POTENTIALLY RELEVANT INFORMATION|>
{%- for memory in memory_results -%}
{% if memory and memory|string|trim %}
{{ memory|condensed }}
---
{% endif %}
{%- endfor -%}
<|CLOSE_SECTION|>
{% endif %}
{% endif %}
{% endif -%}
{# END MEMORY QUERY #}
