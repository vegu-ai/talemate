{#
  CONTEXT RENDERING

  Builds the context sections for contextual generation.
  Uses flags set by the main dispatcher to customize content.

  Flags:
    - exclude_phase_intent: Exclude phase intent from scene-intent
    - include_scene_types: Include scene-types.jinja2
    - include_other_characters: Include descriptions of other characters
    - include_scene_description: Include scene description section
#}

{% if context_aware %}
{# EXTRA CONTEXT CONTENT #}
{% set rendered_context_content %}

{# Extra context #}
{% with include_scenario_premise=True %}
{% include "extra-context-static.jinja2" %}
{% endwith %}

{# Character context #}
{% if character %}
  {% with skip_characters=[character.name] %}{% include "character-context.jinja2" %}{% endwith %}
{% else %}
  {% include "character-context.jinja2" %}
{% endif %}

{# Scene intent - with optional phase exclusion #}
{% if exclude_phase_intent %}
  {% with exclude_phase_intent=True %}{% include "scene-intent.jinja2" %}{% endwith %}
{% else %}
  {% include "scene-intent.jinja2" %}
{% endif %}

{# Scene types - only for scene type contexts #}
{% if include_scene_types %}
  {% include "scene-types.jinja2" %}
{% endif %}

{# Other character descriptions #}
{% if include_other_characters %}
  {% for other_character in scene.get_characters() %}
    {% if other_character.name != character_name %}
<|SECTION:{{ other_character.name }}|>
{{ other_character.description|condensed }}
    {% endif %}
  {% endfor %}
{% endif %}

{# Scene description #}
{% if include_scene_description %}
<|SECTION:SCENE DESCRIPTION|>
{{ scene.description }}
<|CLOSE_SECTION|>
{% endif %}

{% endset %}
{# END EXTRA CONTEXT CONTENT #}

{# VOLATILE CONTEXT #}
{% set volatile_context_text %}
{% include "extra-context-dynamic.jinja2" %}
{% endset -%}
{# END VOLATILE CONTEXT #}

{# PREPARE SCENE HISTORY #}
{% set rendered_context_tokens = count_tokens(rendered_context_content) %}
{% set budget = max_tokens-300-rendered_context_tokens-count_tokens(volatile_context_text) %}
{% if history_aware %}
{% set scene_history = scene.context_history(budget=budget) %}
{% endif %}
{# END PREPARE SCENE HISTORY #}

{# BUILD SCENE CONTEXT #}
{% if history_aware %}
{% set scene_context_text %}
<|SECTION:SCENE|>
{% for scene_line in scene_history %}
{{ scene_line }}
{% endfor %}
<|CLOSE_SECTION|>
{% endset -%}
{% endif %}
{# END BUILD SCENE CONTEXT #}

{# RENDER PROMPT #}
{% set volatile_placement = volatile_context_placement() %}
{{ rendered_context_content }}

{% if volatile_placement != "after_history" %}{{ volatile_context_text }}{% endif %}

{% if history_aware %}{{ scene_context_text }}{% endif %}

{% if volatile_placement == "after_history" %}{{ volatile_context_text }}{% endif %}

{# Character sheet #}
{% if character %}
<|SECTION:{{ character.name }}|>
{% if context_typ == 'character attribute' %}
{{ character.description }}

{% if not character or not character.name %}name: {{ character_name }}{% endif %}
{{ character.sheet_filtered(context_name) }}
{% else %}
{{ character.sheet }}
{% endif %}
<|CLOSE_SECTION|>
{% endif %}

{% else %}
Content Type: {{ scene.context }}
{% endif %}
