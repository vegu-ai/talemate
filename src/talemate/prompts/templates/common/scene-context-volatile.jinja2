{# PREPARE SCENE HISTORY #}
{% set rendered_context_tokens = count_tokens(rendered_context_content) %}
{% set budget = budget_override|default(max_tokens-300-rendered_context_tokens) %}
{% set scene_history = scene.context_history(budget=budget, min_dialogue=min_dialogue|default(20), show_hidden=show_hidden|default(True), keep_director=keep_director|default(True), sections=False) %}
{# END PREPARE SCENE HISTORY #}

{# BUILD SCENE CONTEXT TEXT #}
{% set scene_context_text %}
{% for scene_line in scene_history %}
{{ scene_line }}
{% endfor %}
{% endset %}
{# END BUILD SCENE CONTEXT TEXT #}

{# VOLATILE CONTEXT #}
{% set volatile_context_text %}
{% with _text=scene_context_text %}{% include "internal-note-help.jinja2" %}{% endwith %}
{% with memory_prompt = scene_history %}{% include "memory-context.jinja2" %}{% endwith %}
{% include "extra-context-dynamic.jinja2" %}
{% endset %}
{# END VOLATILE CONTEXT #}

{# RENDER PROMPT #}
{% set volatile_placement = volatile_context_placement() %}
{{ rendered_context_content }}

{% if volatile_placement != "after_history" %}{{ volatile_context_text }}{% endif %}

<|SECTION:SCENE|>
{{ scene_context_text }}
<|CLOSE_SECTION|>

{% if volatile_placement == "after_history" %}{{ volatile_context_text }}{% endif %}
